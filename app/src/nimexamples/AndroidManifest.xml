<?xml version="1.0" encoding="UTF-8"?>
<!--
  EX-M6: Manifest overlay for the `nimexamples` product flavor. Uses
  the namespaced activity class
  `com.metacraft.isonim.examples.MainActivity` so it co-exists with
  the legacy `nimnative` / `native` / `branded` / `baseline` flavors
  (which all use `com.metacraft.isonim.android.MainActivity`).

  `tools:replace="android:name"` is required because the main manifest
  declares the legacy activity name; the new flavor swaps it out
  wholesale.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <application
        android:label="@string/app_name"
        android:theme="@style/Theme.IsoNimExamples"
        tools:replace="android:label,android:theme">
        <!-- Remove the legacy activity declared in the main manifest
             so the nimexamples flavor only ships our examples-rooted
             MainActivity. -->
        <activity
            android:name="com.metacraft.isonim.android.MainActivity"
            tools:node="remove" />
        <activity
            android:name="com.metacraft.isonim.examples.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
